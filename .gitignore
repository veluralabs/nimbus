# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets — NEVER commit a real key. Only the *.example template is tracked.
# Copy assets/service_account.json.example -> assets/service_account.json and
# paste your own GCS service-account key there (see README "Setup").
/assets/service_account.json

# Local Flutter/Gradle machine state
/android/local.properties
/android/key.properties
**/*.keystore
**/*.jks
